# Copy to .env — these defaults work for local docker compose.

# Postgres (used by both the db container and the app)
POSTGRES_DB=closet_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT signing key — change for anything beyond local dev
SECRET=supersecretkey

# MinIO server credentials (consumed by the minio + createbuckets containers)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=closet-ai

# S3 client credentials the app uses — must match the MINIO_* values above
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=closet-ai

# Gemini API key — only needed for embedding generation (in progress)
GEMINI_API_KEY=
